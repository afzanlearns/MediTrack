# MediTrack backend environment template
# Copy to .env for local development and fill in values.

# Profile
SPRING_PROFILES_ACTIVE=local

# Database
DB_URL=jdbc:mysql://localhost:3306/meditrack_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=meditrack
DB_PASSWORD=change_me

# Security
JWT_SECRET=change-me-to-a-long-random-secret
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
