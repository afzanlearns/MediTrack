# ========================
# MediTrack .gitignore
# ========================

# Maven
target/
*.class
*.jar
*.war
*.ear
*.nar

# IDE
.idea/
*.iml
*.iws
*.ipr
.eclipse/
.classpath
.project
.settings/
*.swp
*.swo
.vscode/

# Node / Frontend
node_modules/
dist/
.pnp
.pnp.js

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.*
!.env.example
!.env.*.example

# Backend env files
meditrack-backend/.env
meditrack-backend/.env.*
!meditrack-backend/.env.example

# Frontend env files
meditrack-frontend/.env
meditrack-frontend/.env.*
!meditrack-frontend/.env.example

# Sensitive keys/certs
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.keystore

# Local database dumps/backups
*.dump
*.bak

# Runtime uploads and generated app data
meditrack-backend/uploads/*
!meditrack-backend/uploads/.gitkeep

# Test and coverage artifacts
coverage/
.nyc_output/
*.lcov
surefire-reports/

# Optional: keep local notes out of commits
*.tmp
*.temp
